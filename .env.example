# ── DATABASE (Supabase or any Postgres) ──
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/receipt"

# ── SUPABASE ──
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── CIRCLE (Agent Stack + Wallets + Gateway) ──
CIRCLE_API_KEY="your-circle-api-key"
CIRCLE_ENTITY_SECRET="your-circle-entity-secret"
NEXT_PUBLIC_CIRCLE_APP_ID="your-circle-app-id"

# ── ARC / x402 ──
ARC_RPC_URL="https://rpc.arc.testnet.circle.com"
SELLER_WALLET_ADDRESS="0xYourSellerWalletAddress"
SELLER_PRIVATE_KEY="0xYourSellerPrivateKey"

# ── ANTHROPIC (Agent evaluation) ──
ANTHROPIC_API_KEY="your-anthropic-api-key"

# ── APP ──
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_PLATFORM_FEE_PERCENT="10"
